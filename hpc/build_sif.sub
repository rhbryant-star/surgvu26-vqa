universe = vanilla
executable = build_sif.sh
arguments = latest
log    = build_sif_$(Cluster).log
output = build_sif_$(Cluster).out
error  = build_sif_$(Cluster).err

request_cpus = 4
request_memory = 16GB
request_disk = 60GB
+WantStagingMount = true

should_transfer_files = YES
when_to_transfer_output = ON_EXIT
queue
